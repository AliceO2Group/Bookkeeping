{
  "name": "bookkeeping-server",
  "version": "0.0.0",
  "description": "> TODO: description",
  "author": "ALICEO2",
  "homepage": "https://github.com/AliceO2Group/Bookkeeping#readme",
  "scripts": {
    "coverage": "nyc npm test && npm run coverage:report",
    "coverage:report": "nyc report --reporter=html --reporter=json",
    "lint": "eslint . --ext .js",
    "lint:fix": "npm run lint -- --fix",
    "sequelize": "sequelize-cli",
    "start:dev": "nodemon --ignore 'lib/public/**/*.js' lib/main.js",
    "start:prod": "node lib/main.js",
    "test": "mocha --exit --timeout 0",
    "docker-run": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker-test": "docker compose -p test -f docker-compose.yml -f docker-compose.test.yml up --build --abort-on-container-exit",
    "docker-update": "node scripts/update-dockerfile.js"
  },
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib/",
    "docs/",
    "proto/"
  ],
  "engines": {
    "node": ">= 18.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AliceO2Group/Bookkeeping.git"
  },
  "bugs": {
    "url": "https://github.com/AliceO2Group/Bookkeeping/issues"
  },

  "dependencies": {
    "@aliceo2/web-ui": "2.6.0",
    "@grpc/grpc-js": "1.10.0",
    "@grpc/proto-loader": "0.7.0",
    "cls-hooked": "4.2.2",
    "codemirror": "5.65.16",
    "d3": "7.8.5",
    "deepmerge": "4.3.0",
    "joi": "17.12.0",
    "mariadb": "3.0.0",
    "multer": "1.4.5-lts.1",
    "node-fetch": "3.3.1",
    "sequelize": "6.37.0",
    "umzug": "3.7.0"
  },
  "devDependencies": {
    "chai": "4.4.1",
    "eslint": "8.56.0",
    "js-yaml": "4.1.0",
    "lerna": "8.1.2",
    "mocha": "10.3.0",
    "nodemon": "3.0.1",
    "nyc": "15.1.0",
    "puppeteer": "22.1.0",
    "puppeteer-to-istanbul": "1.4.0",
    "sequelize-cli": "6.6.0",
    "sinon": "17.0.1",
    "supertest": "6.3.0"
  },
  "bundleDependencies": [
    "@aliceo2/web-ui",
    "@grpc/grpc-js",
    "@grpc/proto-loader",
    "cls-hooked",
    "deepmerge",
    "joi",
    "mariadb",
    "multer",
    "node-fetch",
    "sequelize",
    "umzug"
  ]
}
